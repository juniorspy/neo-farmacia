# ============================================
# Neo Farmacia - Environment Variables
# ============================================
# Copy to .env and fill in values

# ---- General ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/neo_farmacia

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Odoo 17 ----
ODOO_URL=http://localhost:8069
ODOO_DB=neo_farmacia
ODOO_USER=admin
ODOO_PASSWORD=admin

# ---- Evolution API (WhatsApp) ----
EVOLUTION_API_URL=https://evo.onrpa.com
EVOLUTION_MASTER_KEY=your_master_key

# ---- n8n ----
N8N_WEBHOOK_URL=https://automations.onrpa.com/webhook/neo-farmacia

# ---- JWT Auth ----
JWT_SECRET=change_this_to_a_random_256bit_string
JWT_EXPIRATION=86400000

# ---- API Keys ----
N8N_API_KEY=shared_key_for_n8n_callbacks

# ---- Dashboard ----
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
